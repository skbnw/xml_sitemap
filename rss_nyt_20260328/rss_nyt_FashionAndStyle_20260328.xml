      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_per">Kennedy, John F Jr</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_per">Kennedy, Carolyn Bessette</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_per">Maxwell, Ghislaine</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_ttl">Love Story: John F. Kennedy Jr. &amp; Carolyn Bessette (TV Program)</category>
