      <media:content height="1798" medium="image" url="https://static01.nyt.com/images/2026/03/20/multimedia/20Bossi--htgq/20Bossi--htgq-mediumSquareAt3X.jpg" width="1800"></media:content>
      <media:credit>Giuseppe Cacace/Agence France-Presse — Getty Images</media:credit>
