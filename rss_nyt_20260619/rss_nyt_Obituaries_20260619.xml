      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_per">Clinton, Hillary Rodham</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_per">Keller, Helen</category>
      <media:content height="1227" medium="image" url="https://static01.nyt.com/images/2026/06/18/multimedia/18houston-jean-fcjt/18houston-jean-fcjt-mediumSquareAt3X.jpg" width="1226"></media:content>
