      <category domain="http://www.nytimes.com/namespaces/keywords/des">Pianos</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/des">Child Abuse and Neglect</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/des">Children and Childhood</category>
      <media:content height="1799" medium="image" url="https://static01.nyt.com/images/2026/04/23/multimedia/23Slenczynska--02-jpmc/23Slenczynska--02-jpmc-mediumSquareAt3X.jpg" width="1800"></media:content>
