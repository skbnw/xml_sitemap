      <media:content height="976" medium="image" url="https://static01.nyt.com/images/2026/05/13/multimedia/04Myers--02-qpcg-print1/04Myers--02-qpcg-mediumSquareAt3X.jpg" width="976"></media:content>
      <media:credit>Reuters</media:credit>
