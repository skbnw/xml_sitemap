      <category domain="http://www.nytimes.com/namespaces/keywords/des">United States International Relations</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_per">Castro, Fidel</category>
      <category domain="http://www.nytimes.com/namespaces/keywords/nyt_geo">Cuba</category>
